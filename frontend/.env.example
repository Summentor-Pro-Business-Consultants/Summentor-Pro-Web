# ── Frontend environment variables ──────────────────────────────────────────
# Copy to `.env.local` and fill in. Restart `next dev` after changes.

# Server-only — used by the Next.js /api/* proxy routes (contact, track, blogs).
# Resolved on the server; never shipped to the browser bundle.
API_URL=http://localhost:9090/api/v1

# Shared secret the proxy routes send to the backend (x-api-key). Server-only.
API_KEY=replace-with-backend-api-key

# Browser-exposed — used by the admin panel (src/lib/admin-api.ts), which calls
# the backend directly from the client. The NEXT_PUBLIC_ prefix is REQUIRED so
# the value is available in the browser. In production set this to the public
# backend URL (e.g. https://api.summentorpro.com/api/v1); if it is missing,
# admin login silently falls back to http://localhost:9090 and fails.
NEXT_PUBLIC_API_URL=http://localhost:9090/api/v1
