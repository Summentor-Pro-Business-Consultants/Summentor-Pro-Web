# ── Frontend environment variables ──────────────────────────────────────────
# Copy to `.env.local` and fill in. Restart `next dev` after changes.
#
# Only TWO variables are needed. Both are server-only (no NEXT_PUBLIC_ prefix):
# every backend call — public pages AND the admin panel — goes through a
# Next.js server-side proxy (/api/*), so the backend URL and key are never
# shipped to the browser. This also means admin auth is same-origin (no CORS,
# first-party refresh cookie) in production.

# Public backend base URL. In production set to your deployed backend, e.g.
# https://your-backend.onrender.com/api/v1
API_URL=http://localhost:9090/api/v1

# Shared secret the proxy routes send to the backend as `x-api-key`.
API_KEY=replace-with-backend-api-key
