{
  "info": {
    "name": "Summentor Pro API",
    "description": "Complete API collection for Summentor Pro.\n\n**Setup:**\n1. Set the `baseUrl` variable to your server (default: `http://localhost:5000/api/v1`).\n2. Set `apiKey` to the value in your backend `.env` (`API_KEY`).\n3. Run **Auth → Login** first — the `accessToken` variable is auto-set from the response.\n\n**Authentication:**\n- All requests include `x-api-key` from the collection variable.\n- Admin endpoints include `Authorization: Bearer {{accessToken}}`.\n- The Login request's test script auto-populates `{{accessToken}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "apiKey",      "value": "your-dev-api-key-here",        "type": "string" },
    { "key": "accessToken", "value": "",                             "type": "string" }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "in",    "value": "header",       "type": "string" },
      { "key": "key",   "value": "x-api-key",    "type": "string" },
      { "key": "value", "value": "{{apiKey}}",   "type": "string" }
    ]
  },
  "item": [

    {
      "name": "Auth",
      "description": "Admin login, token refresh, and logout.",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  console.log('accessToken saved to collection variables.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@summentorpro.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },

    {
      "name": "Contact (Public)",
      "description": "Public contact form endpoint — no JWT required.",
      "item": [
        {
          "name": "Submit Contact Form",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Priya\",\n  \"lastName\": \"Sharma\",\n  \"organisation\": \"Acme Corp\",\n  \"designation\": \"CTO\",\n  \"email\": \"priya.sharma@acmecorp.com\",\n  \"phone\": \"+91 98765 43210\",\n  \"location\": \"Bengaluru, India\",\n  \"industrySector\": \"IT\",\n  \"referralSource\": \"LinkedIn\",\n  \"budget\": \"₹5–10 L\",\n  \"message\": \"Looking for leadership coaching for my senior team.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/contact", "host": ["{{baseUrl}}"], "path": ["contact"] }
          }
        }
      ]
    },

    {
      "name": "Contact (Admin)",
      "description": "Admin contact management — requires Bearer JWT.",
      "item": [
        {
          "name": "List Contact Submissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/contacts?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "contacts"],
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" },
                { "key": "status", "value": "new",    "disabled": true },
                { "key": "search", "value": "Priya",  "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update Contact Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"reviewed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/contacts/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "contacts", ":id", "status"],
              "variable": [{ "key": "id", "value": "3fa85f64-5717-4562-b3fc-2c963f66afa6" }]
            }
          }
        },
        {
          "name": "Delete Contact",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/contacts/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "contacts", ":id"],
              "variable": [{ "key": "id", "value": "3fa85f64-5717-4562-b3fc-2c963f66afa6" }]
            }
          }
        }
      ]
    },

